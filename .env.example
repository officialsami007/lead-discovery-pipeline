NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lead_pipeline
COOKIE_SECRET=replace-with-at-least-32-random-characters
APP_ORIGIN=http://localhost:3000
LOG_LEVEL=info
CRASH_AFTER_DISCOVER_COMMIT=false

# Real lead discovery providers (optional — falls back to mock data when absent)
# Get your Tavily key at https://tavily.com  (used for both Guided and AI Search modes)
TAVILY_API_KEY=
# Get your Groq key at https://console.groq.com  (used only for AI Search mode)
GROQ_API_KEY=
